# ========================================
# TaskEarn Environment Variables
# ========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ========================================
# REQUIRED FOR PRODUCTION
# ========================================

# Secret key for JWT tokens (generate a random 32+ char string)
SECRET_KEY=your-super-secret-key-change-this-in-production

# PostgreSQL Database URL (provided by Railway/Render/Heroku)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/taskearn

# ========================================
# PAYMENT (Razorpay)
# ========================================
# Get these from https://dashboard.razorpay.com/app/keys

RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ========================================
# EMAIL (SendGrid)
# ========================================
# Get API key from https://app.sendgrid.com/settings/api_keys

SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@taskearn.com

# ========================================
# APP SETTINGS
# ========================================

APP_NAME=TaskEarn
APP_URL=https://yourdomain.com
FLASK_ENV=production
DEBUG=False

# CORS - comma separated list of allowed origins
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# JWT token expiration (hours)
JWT_EXPIRATION_HOURS=24

# Rate limiting (requests per minute)
RATE_LIMIT_PER_MINUTE=60
