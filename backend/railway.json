{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "buildpacks": []
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "gunicorn -w 4 -b 0.0.0.0:$PORT server:app",
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 5
  }
}