{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "buildpacks": []
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "sh -c 'gunicorn -w 4 -b 0.0.0.0:${PORT:-5000} --timeout 120 server:app'",
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 5
  }
}