# ========================================
# TaskEarn Production Environment Variables
# ========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ========================================
# REQUIRED FOR PRODUCTION
# ========================================

# Flask environment
FLASK_ENV=production
DEBUG=False

# Secret key for JWT tokens (generate a random 32+ char string)
SECRET_KEY=your-super-secret-key-change-this-in-production-to-random-string

# PostgreSQL Database URL (provided by Railway/Render)
# Format: postgresql://user:password@host:port/database
# Railway auto-sets this - just leave empty if using Railway's default
DATABASE_URL=postgresql://postgres:EipPSaqvFSdRagwxVOWYpXUbtDaEiztw@postgres.railway.internal:5432/railway

# CORS origins (comma-separated list of allowed domains)
CORS_ORIGINS=https://your-frontend-domain.com,https://www.your-frontend-domain.com

# JWT Configuration
JWT_EXPIRATION_HOURS=24

# ========================================
# PAYMENT (Razorpay) - Optional
# ========================================
# Get these from https://dashboard.razorpay.com/app/keys

RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ========================================
# EMAIL (SendGrid) - Optional

SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@taskearn.com

# ========================================
# APP SETTINGS
# ========================================

APP_NAME=TaskEarn
APP_URL=https://yourdomain.com
FLASK_ENV=production
DEBUG=False

# CORS - comma separated list of allowed origins
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# JWT token expiration (hours)
JWT_EXPIRATION_HOURS=24

# Rate limiting (requests per minute)
RATE_LIMIT_PER_MINUTE=60
